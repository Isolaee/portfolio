{
  "family": "portfolio",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "portfolio",
      "image": "ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/portfolio:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV",    "value": "production" },
        { "name": "PORT",        "value": "3000" }
      ],
      "secrets": [
        {
          "name": "PORTFOLIO_NAME",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/portfolio/name"
        },
        {
          "name": "PORTFOLIO_EMAIL",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/portfolio/email"
        },
        {
          "name": "SES_USER",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/portfolio/ses-user"
        },
        {
          "name": "SES_PASS",
          "valueFrom": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/portfolio/ses-pass"
        }
      ],
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:3000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 10
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/portfolio",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
